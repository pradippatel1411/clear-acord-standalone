{
  "name": "@clear-acord/acord",
  "version": "1.0.0",
  "description": "ACORD form mappings, field renderer, PDF generator, and form registry",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./mappings/*": "./mappings/*",
    "./templates/*": "./templates/*"
  },
  "scripts": {
    "type-check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "pdf-lib": "^1.17.1"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "typescript": "^5.9.3"
  }
}
